<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="100" fill="#0a0a0f"/>
  <defs>
    <linearGradient id="beam1" x1="256" y1="60" x2="256" y2="256" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#10b981" stop-opacity="0.1"/>
      <stop offset="80%" stop-color="#10b981" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#6ee7b7" stop-opacity="1"/>
    </linearGradient>
    <radialGradient id="glow1" cx="256" cy="256" r="90" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#6ee7b7" stop-opacity="0.9"/>
      <stop offset="50%" stop-color="#10b981" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <!-- Converging beam lines -->
  <polygon points="200,64 256,256 208,256" fill="url(#beam1)" opacity="0.6"/>
  <polygon points="312,64 256,256 304,256" fill="url(#beam1)" opacity="0.6"/>
  <!-- Center beam -->
  <line x1="256" y1="64" x2="256" y2="256" stroke="#10b981" stroke-width="6" opacity="0.9"/>
  <!-- Focal glow -->
  <circle cx="256" cy="256" r="75" fill="url(#glow1)"/>
  <circle cx="256" cy="256" r="12" fill="#ffffff"/>
  <!-- Material surface line -->
  <line x1="96" y1="288" x2="416" y2="288" stroke="#3f3f46" stroke-width="6"/>
  <!-- Cut groove -->
  <line x1="200" y1="288" x2="312" y2="288" stroke="#10b981" stroke-width="6" opacity="0.8"/>
  <!-- Sparks -->
  <circle cx="218" cy="240" r="5" fill="#fbbf24" opacity="0.8"/>
  <circle cx="298" cy="230" r="4" fill="#fbbf24" opacity="0.6"/>
  <circle cx="235" cy="225" r="4" fill="#fbbf24" opacity="0.7"/>
  <circle cx="278" cy="220" r="3" fill="#fbbf24" opacity="0.5"/>
  <circle cx="245" cy="215" r="3" fill="#fbbf24" opacity="0.6"/>
  <!-- CutLog text -->
  <text x="256" y="400" font-family="Arial,sans-serif" font-size="60" font-weight="bold" fill="#e4e4e7" text-anchor="middle">CutLog</text>
</svg>
