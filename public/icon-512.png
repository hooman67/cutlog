<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="100" fill="#0a0a0f"/>
  <defs>
    <linearGradient id="beam1" x1="256" y1="40" x2="256" y2="270" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#10b981" stop-opacity="0.1"/>
      <stop offset="80%" stop-color="#10b981" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#6ee7b7" stop-opacity="1"/>
    </linearGradient>
    <radialGradient id="glow1" cx="256" cy="270" r="110" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#6ee7b7" stop-opacity="0.9"/>
      <stop offset="50%" stop-color="#10b981" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <!-- Converging beam lines - wider and taller -->
  <polygon points="160,40 256,270 196,270" fill="url(#beam1)" opacity="0.6"/>
  <polygon points="352,40 256,270 316,270" fill="url(#beam1)" opacity="0.6"/>
  <!-- Outer beam edges for more drama -->
  <polygon points="140,40 256,270 186,270" fill="url(#beam1)" opacity="0.3"/>
  <polygon points="372,40 256,270 326,270" fill="url(#beam1)" opacity="0.3"/>
  <!-- Center beam -->
  <line x1="256" y1="40" x2="256" y2="270" stroke="#10b981" stroke-width="7" opacity="0.9"/>
  <!-- Focal glow -->
  <circle cx="256" cy="270" r="100" fill="url(#glow1)"/>
  <circle cx="256" cy="270" r="15" fill="#ffffff"/>
  <!-- Material surface line -->
  <line x1="60" y1="330" x2="452" y2="330" stroke="#3f3f46" stroke-width="6"/>
  <!-- Cut groove -->
  <line x1="160" y1="330" x2="352" y2="330" stroke="#10b981" stroke-width="6" opacity="0.8"/>
  <!-- Sparks -->
  <circle cx="210" cy="248" r="6" fill="#fbbf24" opacity="0.8"/>
  <circle cx="306" cy="238" r="5" fill="#fbbf24" opacity="0.6"/>
  <circle cx="228" cy="232" r="5" fill="#fbbf24" opacity="0.7"/>
  <circle cx="286" cy="224" r="4" fill="#fbbf24" opacity="0.5"/>
  <circle cx="244" cy="218" r="4" fill="#fbbf24" opacity="0.6"/>
  <circle cx="270" cy="212" r="3" fill="#fbbf24" opacity="0.5"/>
</svg>
