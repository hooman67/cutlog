# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini API Key for AI-powered cutting parameter suggestions
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Stripe (WTP / pricing fake-door, see project_docs/4.8_research/IMPL_pricing.md) ---
# OPTIONAL: if these are absent, /pricing still works — the checkout button
# falls back to a "founding members — reserve your spot" confirmation that
# still records intent (no errors). Paste the values from the Stripe dashboard
# to flip the page into taking real money with zero code changes.
#
# Secret key (sk_test_... in test mode, sk_live_... in live mode):
STRIPE_SECRET_KEY=
# Webhook signing secret for POST /api/stripe-webhook (whsec_...):
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (price_...), one per paid tier. Create the Products/Prices
# in the Stripe dashboard, then paste each Price ID here:
STRIPE_PRICE_FOUNDING_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_SHOP=
STRIPE_PRICE_LIFETIME=
STRIPE_PRICE_EXPORT_UNLOCK=

# Public site URL used for Stripe Checkout success/cancel redirects
# (falls back to the request Origin header, then the hard-coded prod URL):
NEXT_PUBLIC_SITE_URL=https://cutlog-two.vercel.app
